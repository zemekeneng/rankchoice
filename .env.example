AWS_PROFILE=default
DOMAIN=rankedchoice.me
PRODUCTION=false

# Local dev — Docker Postgres
DATABASE_URL=postgresql://rankedchoice:password@localhost:5433/rankedchoice

# Production — Neon Serverless Postgres (used by deploy & migrate-prod)
NEON_DATABASE_URL=

# Email service (local dev - Node.js service + MailHog)
EMAIL_SERVICE_URL=http://localhost:3001
EMAIL_SERVICE_API_KEY=dev-api-key-local

# Frontend URL (used for email verification/reset links)
FRONTEND_URL=http://localhost:5174
