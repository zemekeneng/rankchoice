# Email Service Configuration

# Server
NODE_ENV=development
PORT=3001

# API Security (must match backend .env EMAIL_SERVICE_API_KEY)
EMAIL_SERVICE_API_KEY=dev-api-key-local
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000

# MailHog for Local Dev (emails at http://localhost:8026)
# SMTP_HOST=localhost
# SMTP_PORT=1026

# SMTP Configuration (Production)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@domain.com
SMTP_PASS=your-app-password

# Email From Address
FROM_NAME=RankedChoice.me
FROM_EMAIL=noreply@rankedchoice.me

# Development Email Testing (Ethereal Email)
# Get credentials from https://ethereal.email/create
ETHEREAL_USER=ethereal-username
ETHEREAL_PASS=ethereal-password

# AWS SES Configuration (Alternative)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# SES_FROM_EMAIL=noreply@rankedchoice.me